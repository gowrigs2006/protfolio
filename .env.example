# SMTP Server Configuration (Defaults to Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# The email address that will SEND the notifications
SENDER_EMAIL=your-gmail-address@gmail.com

# Google App Password (NOT your regular password!)
# Generate this in Google Account > Security > 2-Step Verification > App Passwords
SENDER_PASSWORD=your-google-app-password-sixteen-chars

# The email address that will RECEIVE the notifications
RECEIVER_EMAIL=gowrishankarponnusamyed1304@gmail.com
